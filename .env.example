# Required
TICKETMASTER_API_KEY=your_ticketmaster_api_key
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
HOME_ADDRESS="Your Address, Austin, TX"

# Spotify OAuth (required for live profile in app.py)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8501

# Optional: enables setlist lookups (free at setlist.fm/api)
SETLISTFM_API_KEY=

# Optional: enables get_similar_artists tool (free at last.fm/api)
LASTFM_API_KEY=

# Optional: Supabase persistence (chat history, click tracking, attendance)
SUPABASE_URL=
SUPABASE_KEY=

# Optional: Twilio SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MY_PHONE_NUMBER=
